---
layout: layouts/base.njk
title: SEO Description Generator
permalink: /seo-tool/
eleventyExcludeFromCollections: true
---
<div class="page" style="max-width: 820px;">
  <h1>SEO description generator</h1>
  <p style="color: var(--text-muted);">Paste your article text below. This pulls three ready-to-use meta description options sized for Google, built entirely in your browser, nothing is sent anywhere.</p>

  <textarea id="input" rows="12" placeholder="Paste your article (markdown is fine, formatting gets stripped automatically)..."
    style="width:100%; padding:16px; border:1px solid var(--line); border-radius:10px; font-family: inherit; font-size:0.98rem; margin: 20px 0 14px; resize: vertical;"></textarea>

  <button id="generate" class="btn">Generate descriptions</button>

  <div id="results" style="margin-top: 30px; display: none;"></div>
</div>

<style>
  .desc-card {
    background: var(--cream-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 22px;
    margin-bottom: 16px;
  }
  .desc-card h3 { font-size: 1rem; margin-bottom: 10px; display:flex; align-items:center; gap:10px; }
  .desc-text { font-size: 1rem; line-height: 1.6; margin-bottom: 12px; color: var(--text); }
  .desc-meta { display:flex; justify-content: space-between; align-items:center; gap: 10px; flex-wrap: wrap; }
  .char-count { font-size: 0.82rem; font-weight: 600; padding: 3px 10px; border-radius: 999px; }
  .char-good { background: #dcefe1; color: #1f6b3a; }
  .char-warn { background: #faf0d6; color: #93690b; }
  .char-bad { background: #f6dcd6; color: #a3341b; }
  .copy-btn {
    background: var(--green-deep);
    color: #fff;
    border: none;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    min-height: 36px;
  }
  .copy-btn:hover { background: var(--green-ink); }
  .copy-btn.copied { background: var(--orange); }
</style>

<script>
(function () {
  function stripMarkdown(md) {
    return md
      .replace(/```[\s\S]*?```/g, " ")
      .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
      .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
      .replace(/^#{1,6}\s+/gm, "")
      .replace(/^>\s?/gm, "")
      .replace(/(\*\*|__)(.*?)\1/g, "$2")
      .replace(/(\*|_)(.*?)\1/g, "$2")
      .replace(/`([^`]*)`/g, "$1")
      .replace(/^[-*+]\s+/gm, "")
      .replace(/^\d+\.\s+/gm, "")
      .replace(/\r/g, "")
      .trim();
  }

  function splitSentences(text) {
    return text.match(/[^.!?]+[.!?]+(\s|$)/g)?.map(function (s) { return s.trim(); }) || [text.trim()];
  }

  function truncateAtWord(text, max) {
    if (text.length <= max) return text;
    var cut = text.slice(0, max);
    var lastSpace = cut.lastIndexOf(" ");
    var base = lastSpace > max * 0.6 ? cut.slice(0, lastSpace) : cut;
    return base.trim().replace(/[,;:\-–]$/, "") + "…";
  }

  function buildDescriptions(markdown) {
    var target = 158;
    var clean = stripMarkdown(markdown);
    var paragraphs = clean.split(/\n\s*\n/)
      .map(function (p) { return p.replace(/\s+/g, " ").trim(); })
      .filter(function (p) { return p.length > 20; });

    if (!paragraphs.length) return null;

    var firstPara = paragraphs[0];
    var sentences = splitSentences(firstPara);

    var primary = "";
    for (var i = 0; i < sentences.length; i++) {
      var candidate = (primary + " " + sentences[i]).trim();
      if (candidate.length <= target) primary = candidate;
      else break;
    }
    if (!primary) primary = truncateAtWord(firstPara, target);

    var alt = paragraphs[1] ? truncateAtWord(paragraphs[1], target) : "";

    var hookCandidates = paragraphs.slice(0, 3).reduce(function (acc, p) {
      return acc.concat(splitSentences(p));
    }, []);
    var hookMatch = hookCandidates.find(function (s) {
      return (/\?|\byou\b|\byour\b/i.test(s)) && s.length > 30 && s.length < target + 20;
    });
    var hook = hookMatch ? truncateAtWord(hookMatch.trim(), target) : "";

    return { primary: primary, alt: alt, hook: hook };
  }

  function charBadge(len) {
    var cls = "char-good", label = "Good length";
    if (len < 70) { cls = "char-bad"; label = "Too short"; }
    else if (len > 165) { cls = "char-bad"; label = "Too long, Google will cut this"; }
    else if (len < 110 || len > 160) { cls = "char-warn"; label = "Okay, could be tighter"; }
    return '<span class="char-count ' + cls + '">' + len + ' chars · ' + label + '</span>';
  }

  function card(title, text) {
    if (!text) return "";
    var id = "d" + Math.random().toString(36).slice(2, 8);
    return '<div class="desc-card">' +
      '<h3>' + title + '</h3>' +
      '<p class="desc-text" id="' + id + '">' + escapeHtml(text) + '</p>' +
      '<div class="desc-meta">' + charBadge(text.length) +
      '<button class="copy-btn" data-target="' + id + '">Copy</button></div>' +
      '</div>';
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c];
    });
  }

  document.getElementById("generate").addEventListener("click", function () {
    var raw = document.getElementById("input").value;
    var out = document.getElementById("results");
    if (!raw.trim()) {
      out.style.display = "block";
      out.innerHTML = '<p style="color: var(--text-muted);">Paste your article text above first.</p>';
      return;
    }
    var d = buildDescriptions(raw);
    if (!d) {
      out.style.display = "block";
      out.innerHTML = '<p style="color: var(--text-muted);">Could not find enough text to work with. Try pasting more of the article.</p>';
      return;
    }
    out.style.display = "block";
    out.innerHTML =
      card("Recommended", d.primary) +
      card("Direct hook (if your article opens with a question or speaks to the reader)", d.hook) +
      card("Alternate", d.alt) +
      '<p style="font-size:0.85rem; color:var(--text-muted); margin-top:6px;">Pick one, copy it, paste it into the Description field in the dashboard when you save the article.</p>';

    out.querySelectorAll(".copy-btn").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var text = document.getElementById(btn.getAttribute("data-target")).textContent;
        navigator.clipboard.writeText(text).then(function () {
          btn.textContent = "Copied";
          btn.classList.add("copied");
          setTimeout(function () { btn.textContent = "Copy"; btn.classList.remove("copied"); }, 1500);
        });
      });
    });
  });
})();
</script>
